# ============================================
# Gambling Platform - Environment Variables
# ============================================

# MongoDB Atlas (REQUIRED)
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gambling-platform?retryWrites=true&w=majority"

# NextAuth (REQUIRED)
NEXTAUTH_SECRET="<generate_with: openssl rand -base64 32>"
NEXTAUTH_URL="http://localhost:3000"

# Upstash Redis (OPTIONAL - caching & rate limiting)
REDIS_URL=""
REDIS_TOKEN=""

# Email - Resend (OPTIONAL - 100 free emails/day)
RESEND_API_KEY=""
FROM_EMAIL="noreply@yourdomain.com"

# Google OAuth (OPTIONAL - social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Razorpay Payments (OPTIONAL - use test keys)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Cloudinary Uploads (OPTIONAL - KYC document uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Encryption (REQUIRED - 32 char random string)
ENCRYPTION_KEY=""
